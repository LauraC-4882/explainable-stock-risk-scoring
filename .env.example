# Optional: override default yfinance request settings
YFINANCE_TIMEOUT=30

# Optional: route US equity history through Twelve Data instead of yfinance
# (fixes Yahoo's datacenter-IP throttling for US tickers — see README "Data
# Quality & Limitations"). Free tier: twelvedata.com, 800 req/day, US-only.
# Unset, US falls back to yfinance (unchanged behavior). CN/HK always use
# akshare regardless of this setting.
# TWELVE_DATA_KEY=

# Optional: point auth/watchlist persistence at a durable external database
# instead of the default local SQLite file — needed on any host whose
# filesystem doesn't survive a restart/redeploy (see README "Known
# limitation: accounts don't survive a redeploy"). Any SQLAlchemy URL, e.g.
# postgresql+psycopg2://user:pw@host/dbname (install the matching driver).
# DATABASE_URL=

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Model artefact storage path
MODEL_DIR=models/artefacts

# Monitoring
MONITORING_LOG_DIR=logs/monitoring
ALERT_EMAIL=

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# Auth — SQLite DB path + JWT signing secret. Leave JWT_SECRET_KEY commented
# out for local dev (the app logs a warning and uses an insecure placeholder);
# uncomment and set a real value before deploying with real users. Generate
# one with: python -c "import secrets; print(secrets.token_hex(32))"
DB_PATH=data/app.db
# JWT_SECRET_KEY=

# Admin account — the site-owner account that can view the usage dashboard,
# ban users, and moderate community posts. Re-created/promoted on every app
# boot from these two values (so it survives the SQLite wipe on each Render
# redeploy — see README "Known limitation"). Unset: no admin account exists
# and admin features stay hidden. Set BOTH here for local admin testing, AND
# in Render's dashboard Environment tab for production — the app can only
# read them, it can't set them for you. Password must be at least 8 chars.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ── [R2] API hardening ───────────────────────────────────────────────────────
# Comma-separated CORS allowlist. Default is local dev origins only. NEVER "*"
# on a deployment with authentication — that lets any site a signed-in user
# visits read this API's responses.
CORS_ALLOWED_ORIGINS=https://your-domain.example

# Set to 1 ONLY behind a reverse proxy that overwrites X-Forwarded-For (Render,
# a CDN). On a directly-exposed server this lets any caller forge a fresh
# client identity per request and bypass IP rate limiting entirely.
TRUST_PROXY_HEADERS=0

# Send Strict-Transport-Security on HTTPS responses. Leave 0 for local dev:
# HSTS on http://localhost pins the dev server to HTTPS in your browser and
# persists after you remove the header.
ENABLE_HSTS=0

# Token bucket. Sustained rate (per second) and burst capacity, per client.
RATE_LIMIT_PER_SECOND=5
RATE_LIMIT_BURST=40
RATE_LIMIT_USER_PER_SECOND=10
RATE_LIMIT_USER_BURST=80
RATE_LIMIT_ENABLED=1

# Failed-login lockout, keyed by account email.
LOGIN_FAILURE_THRESHOLD=5
LOGIN_LOCKOUT_SECONDS=900

# Score cache. fresh = serve without refreshing; stale = how long a cached
# value may still be served after an upstream failure.
SCORE_CACHE_FRESH_SECONDS=300
SCORE_CACHE_STALE_SECONDS=3600

# JWT lifetime, and how close to expiry a token gets silently re-issued.
ACCESS_TOKEN_EXPIRE_MINUTES=720
ACCESS_TOKEN_REFRESH_WITHIN_MINUTES=120

# ── [R1] Backups ─────────────────────────────────────────────────────────────
BACKUP_DIR=backups
BACKUP_RETENTION=10
