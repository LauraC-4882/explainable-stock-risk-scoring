# Optional: override default yfinance request settings
YFINANCE_TIMEOUT=30

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Model artefact storage path
MODEL_DIR=models/artefacts

# Monitoring
MONITORING_LOG_DIR=logs/monitoring
ALERT_EMAIL=

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# Auth — SQLite DB path + JWT signing secret. Leave JWT_SECRET_KEY commented
# out for local dev (the app logs a warning and uses an insecure placeholder);
# uncomment and set a real value before deploying with real users. Generate
# one with: python -c "import secrets; print(secrets.token_hex(32))"
DB_PATH=data/app.db
# JWT_SECRET_KEY=
